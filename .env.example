# Example environment variables for jfrs-candyadmin (Vite)
# Copy this file to .env or .env.local and adjust the values for your environment.

# Application
VITE_APP_TITLE="jfrs Candy Admin"
VITE_APP_TITLE_MASTER="糖果"
VITE_APP_TITLE_SLAVE="管理平台"
VITE_APP_VERSION="1.0.0"
VITE_APP_TECH_SUPPORT="support@example.com"
VITE_APP_ENV="development"

# Vite public base path (if served from a subpath)
VITE_PUBLIC_PATH="/"

# API
# Base URL for backend API, e.g. http://localhost:3000/api
VITE_API_BASE_URL="http://localhost:3000"
# API request timeout in milliseconds
VITE_API_TIMEOUT=10000

# Upload endpoint base (used by image uploader). Can be an absolute URL or path.
VITE_UPLOAD_URL="/upload"

# Feature toggles
# Enable social login UI (true/false)
VITE_ENABLE_SOCIAL_LOGIN="false"

# Any other env variables used by your deployment can be added here.
